  "shuowen": {
    "日": "实也。太阳之精不亏。象形。",
    "月": "阙也。太阴之精。象形。",
    "山": "宣也。宣气散，生万物。象形。",
    "水": "准也。北方之行。象众水并流。",
    "火": "毁也。南方之行。炎而上。象形。",
    "木": "冒也。冒地而生。象形。",
    "人": "天地之性最贵者也。象形。",
    "土": "地之吐生物者也。象形。",
    "金": "五色金也。黄色为长。生于土。",
    "石": "山石也。在厂之下。象形。",
    "天": "颠也。至高无上。会意。",
    "大": "天大、地大、人亦大。象形。",
    "心": "人心。土藏。在身之中。象形。",
    "手": "拳也。象形。",
    "目": "人眼。象形。",
    "口": "人所以言食也。象形。",
    "言": "直言曰言。论难曰语。",
    "文": "错画也。象交文。",
    "字": "乳也。从子在宀下。",
    "书": "箸也。从聿者声。形声。",
    "风": "八风也。从虫凡声。形声。",
    "雨": "水从云下也。象形。",
    "云": "山川气也。从雨云象回转形。",
    "雪": "冰雨说物者。从雨彗声。",
    "一": "惟初太始。道立于一。指事。",
    "上": "高也。指事。",
    "下": "底也。指事。",
    "中": "内也。口丨上下通。指事。",
    "武": "止戈为武。会意。",
    "信": "诚也。从人从言。会意。",
    "明": "照也。从月从囧。会意。",
    "休": "息止也。从人依木。会意。",
    "从": "相听也。从二人。会意。",
    "北": "乖也。从二人相背。会意。",
    "好": "美也。从女从子。会意。",
    "孝": "善事父母者。从老省。会意。",
    "位": "列中庭之左右谓之位。形声。",
    "江": "水。出蜀湔氐徼外岷山。形声。",
    "河": "水。出焞煌塞外昆仑山。形声。",
    "松": "木也。从木公声。形声。",
    "柏": "鞠也。从木白声。形声。",
    "诗": "志也。从言寺声。形声。",
    "词": "意内而言外也。从司言。形声。",
    "经": "织也。从糸巠声。形声。"
  },
