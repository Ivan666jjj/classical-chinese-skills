 "shuowen": {
  "一": "惟初太始，道立于一，造分天地，化成万物。指事。",
  "元": "始也。从一从兀。会意。",
  "天": "颠也。至高无上，从一大。会意。",
  "地": "元气初分，轻清阳为天，重浊阴为地。形声。",
  "人": "天地之性最贵者也。象形。",
  "士": "事也。会意。",
  "王": "天下所归往也。会意。",
  "玉": "石之美有五德者。象形。",
  "气": "云气也。象形。",
  "艹": "百卉也。从二中。象形。",
  "茻": "众草也。从四中。会意。",
  "小": "物之微也。从八，丨见而分之。会意。",
  "八": "别也。象分别相背之形。指事。",
  "采": "捋取也。从木从爪。会意。",
  "半": "物中分也。从八从牛。会意。",
  "牛": "大牲也。象角头三、封尾之形。象形。",
  "犛": "西南夷长髦牛也。形声。",
  "告": "牛触人，角箸横木，所以告人也。会意。",
  "口": "人所以言食也。象形。",
  "凵": "张口也。象形。",
  "吅": "惊呼也。会意。",
  "哭": "哀声也。会意。",
  "走": "趋也。从夭止。会意。",
  "止": "下基也。象草木出有址。象形。",
  "𣥠": "疾也。会意。",
  "步": "行也。从止𣥠相背。会意。",
  "此": "止也。会意。",
  "正": "是也。从止一以止。指事。",
  "是": "直也。从日正。会意。",
  "辵": "乍行乍止也。会意。",
  "彳": "小步也。象胫三属相连。象形。",
  "廴": "长行也。象形。",
  "㢟": "安步㢟㢟也。会意。",
  "行": "人之步趋也。象形。",
  "齒": "口齗骨也。象形。",
  "牙": "壮齿也。象上下相错之形。象形。",
  "足": "人之足也。象形。",
  "疋": "足也。象形。",
  "品": "众庶也。从三口。会意。",
  "龠": "乐之竹管。象形。",
  "冊": "符命也。诸侯进受于王也。象形。",
  "㕯": "言之讷也。会意。",
  "句": "曲也。形声。",
  "丩": "相纠缭也。象形。",
  "古": "故也。从十口。会意。",
  "十": "数之具也。指事。",
  "卅": "三十并也。会意。",
  "言": "直言曰言，论难曰语。形声。",
  "誩": "竞言也。会意。",
  "音": "声也。生于心，有节于外，谓之音。指事。",
  "䇂": "罪也。从干二。会意。",
  "丵": "丛生草也。象形。",
  "菐": "渎菐也。会意。",
  "𠬞": "竦手也。象形。",
  "舁": "共举也。会意。",
  "𠬜": "引也。会意。",
  "𠂤": "小𠂤也。象形。",
  "𠂉": "钩识也。指事。",
  "乚": "匿也。象形。",
  "𠃊": "隐也。指事。",
  "丅": "底也。指事。",
  "丄": "高也。指事。",
  "示": "天垂象，见吉凶，所以示人也。会意。",
  "三": "天地人之道也。指事。",
  "玨": "二玉相合为一珏。会意。",
  "丨": "上下通也。指事。",
  "屮": "草木初生也。象形。",
  "𠂹": "草木花叶𠂹也。象形。",
  "𠌶": "草木花也。会意。",
  "𦻌": "盛貌。会意。",
  "𠃌": "钩逆者谓之𠃌。象形。",
  "𠃋": "𠃋，钩识也。指事。",
  "亅": "钩逆者谓之亅。象形。",
  "𠃍": "钩识也。指事。"
 },
 "jingdian": {
  "天行健": "《周易·乾卦》天行健，君子以自强不息。",
  "地势坤": "《周易·坤卦》地势坤，君子以厚德载物。",
  "潜龙勿用": "《周易·乾卦》潜龙勿用，阳气潜藏。",
  "见龙在田": "《周易·乾卦》见龙在田，利见大人。",
  "飞龙在天": "《周易·乾卦》飞龙在天，利见大人。",
  "亢龙有悔": "《周易·乾卦》亢龙有悔，盈不可久也。",
  "关关雎鸠": "《诗经·周南·关雎》关关雎鸠，在河之洲。窈窕淑女，君子好逑。",
  "蒹葭苍苍": "《诗经·秦风·蒹葭》蒹葭苍苍，白露为霜。所谓伊人，在水一方。",
  "昔我往矣": "《诗经·小雅·采薇》昔我往矣，杨柳依依。今我来思，雨雪霏霏。",
  "投我以木桃": "《诗经·卫风·木瓜》投我以木桃，报之以琼瑶。匪报也，永以为好也。",
  "知我者谓我心忧": "《诗经·王风·黍离》知我者谓我心忧，不知我者谓我何求。",
  "学而时习之": "《论语·学而》学而时习之，不亦说乎？",
  "有朋自远方来": "《论语·学而》有朋自远方来，不亦乐乎？",
  "温故而知新": "《论语·为政》温故而知新，可以为师矣。",
  "学而不思则罔": "《论语·为政》学而不思则罔，思而不学则殆。",
  "知之为知之": "《论语·为政》知之为知之，不知为不知，是知也。",
  "三人行": "《论语·述而》三人行，必有我师焉。",
  "己所不欲": "《论语·颜渊》己所不欲，勿施于人。",
  "言必信": "《论语·子路》言必信，行必果。",
  "道可道": "《老子》道可道，非常道。名可名，非常名。",
  "上善若水": "《老子》上善若水。水善利万物而不争。",
  "大道之行": "《礼记·礼运》大道之行也，天下为公。",
  "大学之道": "《大学》大学之道，在明明德，在亲民，在止于至善。",
  "天命之谓性": "《中庸》天命之谓性，率性之谓道，修道之谓教。",
  "北冥有鱼": "《庄子·逍遥游》北冥有鱼，其名为鲲。鲲之大，不知其几千里也。",
  "先天下之忧而忧": "范仲淹《岳阳楼记》先天下之忧而忧，后天下之乐而乐。",
  "落霞与孤鹜": "王勃《滕王阁序》落霞与孤鹜齐飞，秋水共长天一色。",
  "床前明月光": "李白《静夜思》床前明月光，疑是地上霜。举头望明月，低头思故乡。",
  "白日依山尽": "王之涣《登鹳雀楼》白日依山尽，黄河入海流。欲穷千里目，更上一层楼。",
  "春眠不觉晓": "孟浩然《春晓》春眠不觉晓，处处闻啼鸟。夜来风雨声，花落知多少。"
